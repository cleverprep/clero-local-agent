{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clero Local Agent",
  "version": "0.1.7",
  "identifier": "ai.clero.local-agent",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../.output/public"
  },
  "app": {
    "windows": [
      {
        "title": "Clero Local Agent",
        "width": 470,
        "height": 760,
        "minWidth": 390,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app"],
    "externalBin": ["binaries/clero-local-agent-daemon"],
    "resources": {
      "resources/clero-local-agent-runtime": "clero-local-agent-runtime"
    },
    "macOS": {
      "signingIdentity": "-"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  }
}
